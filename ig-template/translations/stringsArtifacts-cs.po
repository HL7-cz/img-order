# en -> cs

# ActorDefinitionName
#: ActorDefinitionName
msgid "Requirements: Actor Definitions"
msgstr "Požadavky: Definice aktérů (ActorDefinition)"

# ActorDefinitionDesc
#: ActorDefinitionDesc
msgid "The following artifacts define the types of individuals and/or systems that will interact as part of the use cases covered by this implementation guide."
msgstr "Následující artefakty definují typy osob a/nebo systémů, které budou interagovat v rámci případů užití (use cases) popsaných v tomto implementačním průvodci."

# RequirementsName
#: RequirementsName
msgid "Requirements: Formal Requirements"
msgstr "Požadavky: Formální požadavky"

# RequirementsDesc
#: RequirementsDesc
msgid "The following artifacts describe the specific requirements to be met by systems compliant with the implementation guide."
msgstr "Následující artefakty popisují specifické požadavky, které musí splňovat systémy vyhovující tomuto implementačnímu průvodci."

# CapabilityStatementName
#: CapabilityStatementName
msgid "Behavior: Capability Statements"
msgstr "Chování: CapabilityStatements"

# CapabilityStatementDesc
#: CapabilityStatementDesc
msgid "The following artifacts define the specific capabilities that different types of systems are expected to have in order to comply with this implementation guide.  Systems conforming to this implementation guide are expected to declare conformance to one or more of the following capability statements."
msgstr "Následující artefakty definují specifické schopnosti, které se očekávají od různých typů systémů pro zajištění souladu s tímto implementačním průvodcem. Od systémů vyhovujících tomuto průvodci se očekává, že deklarují shodu s jedním nebo více následujícími Capability Statements."

# OperationDefinitionName
#: OperationDefinitionName
msgid "Behavior: Operation Definitions"
msgstr "Chování: Definice operací (OperationDefinition)"

# OperationDefinitionDesc
#: OperationDefinitionDesc
msgid "These are custom operations that can be supported by and/or invoked by systems conforming to this implementation guide."
msgstr "Jedná se o vlastní operace, které mohou být podporovány a/nebo vyvolávány systémy vyhovujícími tomuto implementačnímu průvodci."

# EventDefinitionName
#: EventDefinitionName
msgid "Behavior: Event Definitions"
msgstr "Chování: Definice událostí (EventDefinition)"

# EventDefinitionDesc
#: EventDefinitionDesc
msgid "Defines system and business occurrences that drive a need for data to flow from systems in this implementation guide."
msgstr "Definuje systémové a obchodní události, které vyvolávají potřebu datových toků ze systémů v rámci tohoto implementačního průvodce."

# MessageDefinitionName
#: MessageDefinitionName
msgid "Behavior: Message Definitions"
msgstr "Chování: Definice zpráv (MessageDefinition)"

# MessageDefinitionDesc
#: MessageDefinitionDesc
msgid "These define the types of messages that can be sent and/or received by systems conforming to this implementation guide."
msgstr "Tyto artefakty definují typy zpráv, které mohou být odesílány a/nebo přijímány systémy vyhovujícími tomuto implementačnímu průvodci."

# SearchParameterName
#: SearchParameterName
msgid "Behavior: Search Parameters"
msgstr "Chování: Vyhledávací parametry (SearchParameter)"

# SearchParameterDesc
#: SearchParameterDesc
msgid "These define the properties by which a RESTful server can be searched.  They can also be used for sorting and including related resources."
msgstr "Tyto artefakty definují vlastnosti, podle kterých lze prohledávat RESTful server. Mohou být také použity pro řazení a vkládání souvisejících zdrojů."

# SubscriptionTopicName
#: SubscriptionTopicName
msgid "Behavior: Subscription Topics"
msgstr "Chování: Témata odběrů (SubscriptionTopic)"

# SubscriptionTopicDesc
#: SubscriptionTopicDesc
msgid "These define the types of information that can be subscribed to on systems conforming to this this implementation guide."
msgstr "Tyto artefakty definují typy informací, které lze odebírat v systémech vyhovujících tomuto implementačnímu průvodci."

# ActivityDefinitionName
#: ActivityDefinitionName
msgid "Knowledge Artifacts: Activity Definitions"
msgstr "Znalostní artefakty: Definice aktivit (ActivityDefinition)"

# ActivityDefinitionDesc
#: ActivityDefinitionDesc
msgid "These define activities that can be performed as part of content in this implementation guide."
msgstr "Tyto artefakty definují aktivity, které mohou být prováděny jako součást obsahu v tomto implementačním průvodci."

# PlanDefinitionName
#: PlanDefinitionName
msgid "Knowledge Artifacts: Plan Definitions"
msgstr "Znalostní artefakty: Definice plánů (PlanDefinition)"

# PlanDefinitionDesc
#: PlanDefinitionDesc
msgid "These define workflows, rules, strategies, or protocols as part of content in this implementation guide."
msgstr "Tyto artefakty definují pracovní postupy (workflows), pravidla, strategie nebo protokoly jako součást obsahu v tomto implementačním průvodci."

# MeasureName
#: MeasureName
msgid "Knowledge Artifacts: Measure"
msgstr "Znalostní artefakty: Measure (Metriky)"

# MeasureDesc
#: MeasureDesc
msgid "These define measures as part of content in this implementation guide."
msgstr "Tyto artefakty definují metriky (measures) jako součást obsahu v tomto implementačním průvodci."

# LibraryName
#: LibraryName
msgid "Knowledge Artifacts: Libraries"
msgstr "Znalostní artefakty: Knihovny (Library)"

# LibraryDesc
#: LibraryDesc
msgid "These define logic, asset collections and other libraries as part of content in this implementation guide."
msgstr "Tyto artefakty definují logiku, sbírky aktiv a další knihovny jako součást obsahu v tomto implementačním průvodci."

# EvidenceName
#: EvidenceName
msgid "Knowledge Artifacts: Evidence"
msgstr "Znalostní artefakty: Evidence (Důkazy)"

# EvidenceDesc
#: EvidenceDesc
msgid "Indicates research or other information that justifies or support the information exchange defined in this implemetnation guide."
msgstr "Označuje výzkum nebo jiné informace, které odůvodňují nebo podporují výměnu informací definovanou v tomto implementačním průvodci."

# EvidenceVariableName
#: EvidenceVariableName
msgid "Knowledge Artifacts: Evidence Variables"
msgstr "Znalostní artefakty: EvidenceVariables (Proměnné důkazů)"

# EvidenceVariableDesc
#: EvidenceVariableDesc
msgid "Components of the research that justify or support the information exchange defined in this implementation guide."
msgstr "Komponenty výzkumu, které odůvodňují nebo podporují výměnu informací definovanou v tomto implementačním průvodci."

# CitationNameName
#: CitationNameName
msgid "Knowledge Artifacts: Citations"
msgstr "Znalostní artefakty: Citace (Citation)"

# CitationNameDesc
#: CitationNameDesc
msgid "Supports referencing artifacts defined in this implementation guide."
msgstr "Podporuje odkazování na artefakty definované v tomto implementačním průvodci."

# ResourceName
#: ResourceName
msgid "Structures: Additional Resources"
msgstr "Struktury: Dodatečné zdroje"

# ResourceDesc
#: ResourceDesc
msgid "'Additional' resources that are not yet published in the FHIR core specification."
msgstr "Dodatečné („Additional“) zdroje, které ještě nejsou publikovány v hlavní specifikaci FHIR."

# GraphDefinitionName
#: GraphDefinitionName
msgid "Structures: Graph Definitions"
msgstr "Struktury: Definice grafů (GraphDefinition)"

# GraphDefinitionDesc
#: GraphDefinitionDesc
msgid "These define collections of interrelated resources that are useful to pass around as a group."
msgstr "Tyto artefakty definují sbírky vzájemně propojených zdrojů, které je užitečné předávat jako celek."

# LogicalModelName
#: LogicalModelName
msgid "Structures: Logical Models"
msgstr "Struktury: Logické modely"

# LogicalModelDesc
#: LogicalModelDesc
msgid "These define data models that represent the domain covered by this implementation guide in more business-friendly terms than the underlying FHIR resources."
msgstr "Tyto artefakty definují datové modely, které reprezentují doménu pokrytou tímto implementačním průvodcem v termínech srozumitelnějších pro business než základní FHIR zdroje."